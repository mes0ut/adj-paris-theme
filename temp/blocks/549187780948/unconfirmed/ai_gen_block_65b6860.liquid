{% doc %}
  @prompt
    ios ve androidd ap indirme butonları
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-app-download-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-app-download-container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: {{ block.settings.alignment }};
    gap: {{ block.settings.spacing }}px;
  }

  .ai-app-download-heading-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    text-align: {{ block.settings.alignment }};
  }

  .ai-app-download-text-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    text-align: {{ block.settings.alignment }};
  }

  .ai-app-download-buttons-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: {{ block.settings.button_spacing }}px;
    justify-content: {{ block.settings.alignment }};
  }

  .ai-app-download-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px 24px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    text-decoration: none;
    transition: all 0.3s ease;
    font-size: {{ block.settings.button_text_size }}px;
  }

  .ai-app-download-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
    transform: translateY(-2px);
  }

  .ai-app-download-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
  }

  .ai-app-download-button-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    line-height: 1.2;
  }

  .ai-app-download-button-label-{{ ai_gen_id }} {
    font-size: 0.7em;
    opacity: 0.8;
  }

  .ai-app-download-button-store-{{ ai_gen_id }} {
    font-weight: 600;
  }

  @media screen and (max-width: 749px) {
    .ai-app-download-buttons-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-app-download-button-{{ ai_gen_id }} {
      flex: 1;
      min-width: 140px;
      justify-content: center;
    }
  }
{% endstyle %}

<app-download-buttons-{{ ai_gen_id }}
  class="ai-app-download-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-app-download-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-app-download-heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h2>
    {% endif %}

    {% if block.settings.text != blank %}
      <div class="ai-app-download-text-{{ ai_gen_id }}">
        {{ block.settings.text }}
      </div>
    {% endif %}

    <div class="ai-app-download-buttons-{{ ai_gen_id }}">
      {% if block.settings.show_ios and block.settings.ios_link != blank %}
        <a
          href="{{ block.settings.ios_link }}"
          class="ai-app-download-button-{{ ai_gen_id }}"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Download on the App Store"
        >
          <svg
            class="ai-app-download-icon-{{ ai_gen_id }}"
            viewBox="0 0 24 24"
            fill="currentColor"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path d="M18.71 19.5C17.88 20.74 17 21.95 15.66 21.97C14.32 22 13.89 21.18 12.37 21.18C10.84 21.18 10.37 21.95 9.09997 22C7.78997 22.05 6.79997 20.68 5.95997 19.47C4.24997 17 2.93997 12.45 4.69997 9.39C5.56997 7.87 7.12997 6.91 8.81997 6.88C10.1 6.86 11.32 7.75 12.11 7.75C12.89 7.75 14.37 6.68 15.92 6.84C16.57 6.87 18.39 7.1 19.56 8.82C19.47 8.88 17.39 10.1 17.41 12.63C17.44 15.65 20.06 16.66 20.09 16.67C20.06 16.74 19.67 18.11 18.71 19.5ZM13 3.5C13.73 2.67 14.94 2.04 15.94 2C16.07 3.17 15.6 4.35 14.9 5.19C14.21 6.04 13.07 6.7 11.95 6.61C11.8 5.46 12.36 4.26 13 3.5Z"/>
          </svg>
          <div class="ai-app-download-button-content-{{ ai_gen_id }}">
            <span class="ai-app-download-button-label-{{ ai_gen_id }}">{{ block.settings.ios_label }}</span>
            <span class="ai-app-download-button-store-{{ ai_gen_id }}">App Store</span>
          </div>
        </a>
      {% endif %}

      {% if block.settings.show_android and block.settings.android_link != blank %}
        <a
          href="{{ block.settings.android_link }}"
          class="ai-app-download-button-{{ ai_gen_id }}"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Get it on Google Play"
        >
          <svg
            class="ai-app-download-icon-{{ ai_gen_id }}"
            viewBox="0 0 24 24"
            fill="currentColor"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 0 1-.61-.92V2.734a1 1 0 0 1 .609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.198l2.807 1.626a1 1 0 0 1 0 1.73l-2.808 1.626L15.206 12l2.492-2.491zM5.864 2.658L16.802 8.99l-2.303 2.303-8.635-8.635z"/>
          </svg>
          <div class="ai-app-download-button-content-{{ ai_gen_id }}">
            <span class="ai-app-download-button-label-{{ ai_gen_id }}">{{ block.settings.android_label }}</span>
            <span class="ai-app-download-button-store-{{ ai_gen_id }}">Google Play</span>
          </div>
        </a>
      {% endif %}
    </div>
  </div>
</app-download-buttons-{{ ai_gen_id }}>

<script>
  (function() {
    class AppDownloadButtons{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.buttons = this.querySelectorAll('.ai-app-download-button-{{ ai_gen_id }}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.buttons.forEach((button) => {
          button.addEventListener('click', (e) => {
            const platform = button.getAttribute('aria-label').includes('App Store') ? 'iOS' : 'Android';
            console.log(`App download clicked: ${platform}`);
          });
        });
      }
    }

    customElements.define('app-download-buttons-{{ ai_gen_id }}', AppDownloadButtons{{ ai_gen_id }});
  })();
</script>

